DATABASE_URL="postgresql://user:password@localhost:5432/solara_os?schema=public"
# Direct (non-pooled/non-Accelerate) connection, used only for running
# migrations. Locally this is normally identical to DATABASE_URL. On Vercel
# with Prisma Postgres, this should be the direct postgres:// connection
# string (Vercel's Prisma Postgres integration sets this automatically).
POSTGRES_URL="postgresql://user:password@localhost:5432/solara_os?schema=public"
